# Excel input
EXCEL_FILE_PATH=links.xlsx
EXCEL_SHEET_NAME=Sheet1

# Fast-index panel credentials
PANEL_URL=https://fast-index.icu/botfarms/panel.php
HISTORY_URL_BASE=https://fast-index.icu/botfarms/enemy/check_all.php
PANEL_USERNAME=your_username
PANEL_PASSWORD=your_password

# Runtime options
HEADLESS=true
MAX_LINKS_PER_BATCH=500
RETRY_COUNT=3
RETRY_DELAY_SECONDS=3
LOGIN_WAIT_SECONDS=25
ACTION_DELAY_SECONDS=1.5
SUBMISSION_WAIT_SECONDS=6

# Post-submit sheet action:
# none | clear | move
POST_SUBMIT_ACTION=none
SUBMITTED_SHEET_NAME=Submitted

# Optional scheduler in minutes (0 disables)
RUN_INTERVAL_MINUTES=0

# Local cookie cache file
COOKIES_FILE=cookies.json
